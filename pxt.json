{
    "name": "butia-microbit-extension",
    "version": "0.1.0",
    "description": "MakeCode extension for the Butia v4 educational robotics kit — imperative and event-based block paradigms.",
    "dependencies": {
        "core": "*"
    },
    "files": [
        "src/blocks/events.ts",
        "src/blocks/imperative.ts",
        "src/core/connector.ts",
        "src/core/constants.ts",
        "src/core/robot-base.ts",
        "src/hardware/butia-robot.ts",
        "src/hardware/button-sensor-butia.ts",
        "src/hardware/distance-sensor-butia.ts",
        "src/hardware/gpio-motor-driver.ts",
        "src/hardware/gray-sensor-butia.ts",
        "src/hardware/light-sensor-butia.ts",
        "src/main.ts",
        "src/robotdriver.ts",
        "src/types/components.d.ts",
        "src/types/enums.d.ts",
        "src/types/robot.d.ts",
        "README.md"
    ],
    "testFiles": [
        "test/mock.test.ts",
        "test/robot.test.ts",
        "test/sensor.test.ts"
    ],
    "targetVersions": {
